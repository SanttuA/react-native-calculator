{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_NO_TELEMETRY": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_NO_TELEMETRY": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_NO_TELEMETRY": "1"
      }
    },
    "e2e-test": {
      "withoutCredentials": true,
      "env": {
        "EXPO_NO_TELEMETRY": "1"
      },
      "android": {
        "buildType": "apk"
      }
    }
  }
}
