{
  "name": "laskin",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "node ./scripts/expo-no-telemetry.js start",
    "android": "node ./scripts/expo-no-telemetry.js start --android",
    "typecheck": "tsc --noEmit",
    "lint": "node ./scripts/expo-no-telemetry.js lint",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test:ci",
    "audit:prod": "npm audit --omit=dev --audit-level=moderate",
    "e2e:android": "maestro test .maestro/calculator.yml"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.33",
    "decimal.js": "^10.6.0",
    "expo": "~55.0.23",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-splash-screen": "~55.0.20",
    "lucide-react-native": "^1.14.0",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.17",
    "prettier": "^3.8.3",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "private": true
}
